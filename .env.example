# JWT Secret Key (generate with: openssl rand -hex 32)
SECRET_KEY=secret

# SMTP Configuration for Email Service (using Mailjet)
MAILJET_APIKEY=secret
MAILJET_SECRET=secret

# Frontend Domain
WEBDOMAIN=http://localhost:3000
# Frontend Session Secret (generate with: openssl rand -hex 32)
SESSION_SECRET=secret

# Mapbox Access Token (get from https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
NEXT_PUBLIC_SUPPORT_EMAIL=your_support_email_here

# Storage path for file uploads and exports
STORAGE_PATH=./storage

# Telegram Notification Settings (fallback defaults; DB settings override these)
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPERVISOR_GROUP_ID=
TELEGRAM_ENUMERATOR_GROUP_ID=